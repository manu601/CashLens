<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 CashLens"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="See where your money goes"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <!-- Balance Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#2E7D32">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Balance"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KSh 0.00"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
        <!--Fuliza satus-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuliza Outstanding"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtFulizaOutstanding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KSh 0.00"
                    android:textSize="20sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available Fuliza"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtFulizaLimit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KSh 0.00"
                    android:textSize="20sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Spending -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Spending"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KSh 0.00"
            android:textSize="22sp"/>

        <!-- Recent Transactions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Transactions"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="24dp"/>
        <Button
            android:id="@+id/btnImportSms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Import M-PESA Messages"/>
        <!--Database Reset Button-->
        <Button
            android:id="@+id/btnResetDatabase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Reset Database"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"/>

        <LinearLayout
            android:id="@+id/importStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp">

            <TextView
                android:id="@+id/importText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Importing transactions..."
                android:textSize="16sp"/>

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:id="@+id/importProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"/>

        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTransactions"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</ScrollView>